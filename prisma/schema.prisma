generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Project {
  id String @id @default(cuid())

  slug String @unique

  titleFa String
  titleEn String

  cityFa String
  cityEn String

  developerNameFa String
  developerNameEn String

  usageFa String
  usageEn String

  addressFa String
  addressEn String

  imagePath    String?
  brochureFile String?

  downloadEvents DownloadEvent[]

  isActive       Boolean @default(true)
  visibleInIndex Boolean @default(true)
  sortOrder      Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, visibleInIndex, sortOrder])
}

model User {
  id String @id @default(cuid())

  fullName String
  phone    String @unique
  jobTitle String

  registrationSessions  RegistrationSession[]
  downloadEvents        DownloadEvent[]
  journalDownloadEvents GeneralJournalDownloadEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RegistrationSession {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  tokenHash String @unique

  expiresAt DateTime
  revokedAt DateTime?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model DownloadEvent {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Restrict)

  downloadedAt DateTime @default(now())

  @@index([userId])
  @@index([projectId])
  @@index([downloadedAt])
  @@index([projectId, downloadedAt])
  @@index([userId, downloadedAt])
}

model GeneralJournal {
  id String @id @default(cuid())

  titleFa String
  titleEn String

  fileName         String
  originalFileName String?

  isActive Boolean @default(true)

  downloadEvents GeneralJournalDownloadEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
}

model GeneralJournalDownloadEvent {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  journalId String
  journal   GeneralJournal @relation(fields: [journalId], references: [id], onDelete: Restrict)

  downloadedAt DateTime @default(now())

  @@index([userId])
  @@index([journalId])
  @@index([downloadedAt])
  @@index([journalId, downloadedAt])
  @@index([userId, downloadedAt])
}
